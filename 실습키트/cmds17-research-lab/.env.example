# =============================================================
# CMDS 17회차 Research Lab — 환경변수 예시
# 이 파일을 .env 로 복사한 뒤(= cp .env.example .env) 값을 채우세요.
# 값에 따옴표를 붙이지 말고 = 뒤에 바로 입력합니다.
# 발급 방법은 api_keys/00_api_key_guide.md 참고.
# =============================================================

# ---------- 필수 3종 (무료, 카드 불필요) ----------

# Google AI Studio — Gemini API 키 (형식: AIza...)
# 발급처: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Tavily — 웹 검색 API (형식: tvly-...)  무료 1,000 크레딧/월
# 발급처: https://app.tavily.com/home
TAVILY_API_KEY=

# Firecrawl — 웹 스크래핑 API (형식: fc-...)  Free 플랜
# 발급처: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# ---------- 선택 (필요 시 추가) ----------

# Apify — 스크래퍼(Actor) 토큰 (형식: apify_api_...)  무료 $5/월
# 발급처: https://console.apify.com/  (Settings → API & Integrations)
APIFY_TOKEN=

# Brave Search API — 검색 API  무료 $5 크레딧/월 (구독 시 카드 등록 필요)
# 발급처: https://api-dashboard.search.brave.com/
BRAVE_API_KEY=

# Exa — 시맨틱 검색 API  가입 시 무료 크레딧
# 발급처: https://dashboard.exa.ai/
EXA_API_KEY=

# SerpAPI — 구글 SERP 구조화 API (64자 hex)  무료 100 검색/월
# 발급처: https://serpapi.com/users/sign_up
SERPAPI_KEY=

# 법제처 OPEN API — OC키(=가입 이메일의 @ 앞 아이디, 무료)
# 발급처: https://open.law.go.kr/  (회원가입 후 OPEN API 사용 신청)
LAW_OC=
